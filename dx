#!/bin/bash
set -e
export LANG=C.UTF-8
export LC_ALL=C.UTF-8
source /opt/lib/common.sh
init_defaults

# ================= user management =================
cmd_add_user() {
  local label="$1"
  [ -z "$label" ] && label="dx_$(head -c3 /dev/urandom | od -An -tx1 | tr -d ' ')"
  if jq -e --arg u "$label" '.users[] | select(.user==$u)' "$USERS_FILE" >/dev/null; then
    echo "Error: user '$label' already exists"; exit 1
  fi
  local domain secret
  domain=$(jq -r '.fake_tls_domain' "$SETTINGS_FILE")
  secret=$(generate_secret "$domain")
  jq --arg u "$label" --arg s "$secret" \
    '.users += [{user:$u, secret:$s, enabled:true, created_at:(now|todate)}]' \
    "$USERS_FILE" > "$USERS_FILE.tmp" && mv "$USERS_FILE.tmp" "$USERS_FILE"
  regen_config
  echo "Added user: $label"
  echo "Link: $(build_link "$secret")"
}

cmd_remove_user() {
  local u="$1"
  [ -z "$u" ] && { echo "Usage: dx remove-user <user>"; exit 1; }
  jq --arg u "$u" '.users |= map(select(.user != $u))' "$USERS_FILE" > "$USERS_FILE.tmp" && mv "$USERS_FILE.tmp" "$USERS_FILE"
  regen_config
  echo "Removed user: $u"
}

cmd_set_enabled() {
  local u="$1" val="$2"
  jq --arg u "$u" --argjson v "$val" \
    '.users |= map(if .user==$u then .enabled=$v else . end)' \
    "$USERS_FILE" > "$USERS_FILE.tmp" && mv "$USERS_FILE.tmp" "$USERS_FILE"
  regen_config
  echo "User $u enabled=$val"
}

cmd_rotate_secret() {
  local u="$1" domain newsecret
  domain=$(jq -r '.fake_tls_domain' "$SETTINGS_FILE")
  newsecret=$(generate_secret "$domain")
  jq --arg u "$u" --arg s "$newsecret" \
    '.users |= map(if .user==$u then .secret=$s else . end)' \
    "$USERS_FILE" > "$USERS_FILE.tmp" && mv "$USERS_FILE.tmp" "$USERS_FILE"
  regen_config
  echo "Rotated secret for $u"
  echo "Link: $(build_link "$newsecret")"
}

cmd_users() {
  if [ "$1" = "--json" ]; then
    json_users
    return
  fi
  printf "%-16s %-8s %-70s\n" "USER" "ENABLED" "SECRET"
  jq -r '.users[] | "\(.user)\t\(.enabled)\t\(.secret)"' "$USERS_FILE" | \
  while IFS=$'\t' read -r u e s; do
    printf "%-16s %-8s %-70s\n" "$u" "$e" "$s"
  done
}

cmd_info() {
  if [ "$1" = "--json" ]; then
    local proxy_host proxy_port
    proxy_host=$(jq -r '.proxy_host // ""' "$SETTINGS_FILE")
    proxy_port=$(jq -r '.proxy_port // ""' "$SETTINGS_FILE")
    jq --arg h "$proxy_host" --arg p "$proxy_port" '
      [ .users[] | select(.enabled==true) | {
        user, secret,
        link: (if $h=="" or $p=="" then null
               else ("https://t.me/proxy?server="+$h+"&port="+$p+"&secret="+.secret)
               end)
      } ]
    ' "$USERS_FILE"
    return
  fi
  jq -r '.users[] | select(.enabled==true) | "\(.user)\t\(.secret)"' "$USERS_FILE" | \
  while IFS=$'\t' read -r u s; do
    echo "# $u"
    echo "$(build_link "$s")"
    echo ""
  done
}

cmd_settings() {
  if [ "$1" = "--json" ]; then
    json_settings
    return
  fi
  jq . "$SETTINGS_FILE"
}

cmd_export() {
  echo "user,secret,link"
  jq -r '.users[] | "\(.user),\(.secret)"' "$USERS_FILE" | \
  while IFS=, read -r u s; do
    echo "$u,$s,$(build_link "$s")"
  done
}

# ================= proxy / settings =================
cmd_set_proxy() {
  local hostport="$1"
  [ -z "$hostport" ] && { echo "Usage: dx set-proxy <host:port>"; exit 1; }

  local normalized
  if ! normalized=$(normalize_host_port "$hostport"); then
    exit 1
  fi

  local host port
  if [[ "$normalized" == *:* ]]; then
    host="${normalized%%:*}"
    port="${normalized##*:}"
  else
    host="$normalized"
    port=""
  fi

  jq --arg h "$host" --arg p "$port" '.proxy_host=$h | .proxy_port=$p' \
    "$SETTINGS_FILE" > "$SETTINGS_FILE.tmp" && mv "$SETTINGS_FILE.tmp" "$SETTINGS_FILE"
  if [ -n "$port" ]; then
    echo "Proxy set to $host:$port"
  else
    echo "Proxy set to $host"
  fi
}

cmd_set_domain() {
  local d="$1"
  [ -z "$d" ] && { echo "Usage: dx set-domain <fake-tls-domain>"; exit 1; }
  jq --arg d "$d" '.fake_tls_domain=$d' "$SETTINGS_FILE" > "$SETTINGS_FILE.tmp" && mv "$SETTINGS_FILE.tmp" "$SETTINGS_FILE"
  echo "Fake-TLS domain set to $d (applies to newly generated/rotated secrets only)"
}

# ================= panel auth =================
cmd_panel_password() {
  local user="$1" pass="$2"
  [ -z "$user" ] || [ -z "$pass" ] && { echo "Usage: dx panel-password <username> <password>"; exit 1; }
  local hash
  hash=$(node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" "$pass")
  # Any real password change clears must_change_password, including the
  # first-run one the operator is being forced through.
  jq -n --arg u "$user" --arg h "$hash" '{username:$u, password_hash:$h, must_change_password:false}' > "$AUTH_FILE"
  echo "Panel login updated -> username: $user"
}

cmd_auth_status() {
  if [ "$1" = "--json" ]; then
    json_auth_status
    return
  fi
  jq -r '"username: \(.username)\nmust_change_password: \(.must_change_password // false)"' "$AUTH_FILE"
}

# ================= stats =================
cmd_stats() {
  curl -s "http://127.0.0.1:${STATS_PORT:-9090}/stats" | jq . 2>/dev/null || \
    echo "Stats endpoint not reachable (is mtg-multi running?)"
}

# ================= service control =================
cmd_status() {
  if [ "$1" = "--json" ]; then
    json_status
    return
  fi
  echo "== mtg-multi process =="
  pgrep -a mtg-multi || echo "not running"
  echo "== Panel process =="
  pgrep -af "node /opt/panel/server.js" || echo "not running"
  echo "== Users =="
  jq -r '.users | length' "$USERS_FILE"
}

cmd_restart() {
  regen_config
  echo "Reload flag set — watchdog will restart mtg-multi shortly"
}

cmd_logs() {
  tail -n 50 "$DATA_DIR/mtg.log" 2>/dev/null || echo "no log file yet"
}

# ================= backup/restore =================
cmd_backup() {
  local out="dx-backup-$(date +%Y%m%d-%H%M%S).tar.gz"
  tar -czf "/tmp/$out" -C "$DATA_DIR" users.json settings.json panel_auth.json
  echo "Backup written to /tmp/$out (download via Railway console file transfer, or `dx export` for a plain-text copy)"
}

cmd_restore() {
  local file="$1"
  [ -z "$file" ] || [ ! -f "$file" ] && { echo "Usage: dx restore <path-to-tar.gz>"; exit 1; }
  local tmp
  tmp=$(mktemp -d)
  tar -tzf "$file" | grep -qE '^(users\.json|settings\.json|panel_auth\.json)$' || { echo "Invalid backup archive"; exit 1; }
  tar -xzf "$file" -C "$tmp"
  [ -f "$tmp/users.json" ] && jq empty "$tmp/users.json" || { echo "users.json invalid JSON"; exit 1; }
  cp "$tmp/"*.json "$DATA_DIR/"
  regen_config
  echo "Restored from $file"
}

cmd_new() {
  rm -f "$USERS_FILE"
  init_defaults
  regen_config
  echo "Wiped all users, generated a fresh admin"
}

# ================= menu rendering =================
MENU_WIDTH=72

# Colors — only when stdout is a real terminal and NO_COLOR is unset
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  _CR=$'\033[0m'; _CG=$'\033[0;32m'; _CRD=$'\033[0;31m'
else
  _CR=''; _CG=''; _CRD=''
fi

# Strip ANSI escape sequences for printable-width measurement
_sa() {
  local esc=$'\033'
  echo "$1" | sed "s/${esc}\\[[0-9;]*m//g"
}

# Printable character count (ignores ANSI codes)
_pw() {
  local val
  val=$(_sa "$1")
  echo "${#val}"
}

# Emit N copies of a character
_rp() {
  [ "$2" -le 0 ] && return
  printf '%0.s'"$1" $(seq 1 "$2")
}

# Clear the terminal screen and reset cursor position robustly, clearing scrollback history as well
_clear_screen() {
  clear 2>/dev/null || true
  printf "\033[2J\033[3J\033[H"
}

# Discard any pending keystrokes or newlines in the stdin buffer safely with a timeout
_flush_stdin() {
  [ -t 0 ] || return 0
  local discard
  while read -t 0 -r discard; do
    read -t 0.1 -r discard
  done
}

# ── box-drawing primitives (all lines = MENU_WIDTH printable chars) ──
_top() { printf '╔'; _rp '═' $((MENU_WIDTH-2)); printf '╗\n'; }
_bot() { printf '╚'; _rp '═' $((MENU_WIDTH-2)); printf '╝\n'; }
_sep() { printf '╠'; _rp '═' $((MENU_WIDTH-2)); printf '╣\n'; }
_emp() { printf '║'; _rp ' ' $((MENU_WIDTH-2)); printf '║\n'; }

# Centered content row: ║<pad><text><pad>║
_ctr() {
  local w; w=$(_pw "$1")
  local inner=$((MENU_WIDTH-2))
  local lpad=$(( (inner-w)/2 ))
  local rpad=$(( inner-w-lpad ))
  printf '║'; _rp ' ' "$lpad"; printf '%s' "$1"; _rp ' ' "$rpad"; printf '║\n'
}

# Left-aligned row: ║ <text><pad>║
_lft() {
  local w; w=$(_pw "$1")
  local rpad=$(( MENU_WIDTH-3-w ))
  [ "$rpad" -lt 0 ] && rpad=0
  printf '║ %s' "$1"; _rp ' ' "$rpad"; printf '║\n'
}

# Split row (left text + right text, gap-filled): ║ <left><gap><right>║
_spt() {
  local lw; lw=$(_pw "$1")
  local rw; rw=$(_pw "$2")
  local gap=$(( MENU_WIDTH-3-lw-rw ))
  [ "$gap" -lt 0 ] && gap=0
  printf '║ %s%*s%s' "$1" "$gap" "" "$2"
  printf '║\n'
}

# Proxy-status row with ANSI colour
_sts() {
  local running
  running=$(pgrep -x mtg-multi >/dev/null 2>&1 && echo true || echo false)

  local label="Proxy Status:   "
  local lw; lw=$(_pw "$label")
  local sw=7  # "RUNNING" or "STOPPED" — same printable length

  local colour
  if [ "$running" = "true" ]; then colour="${_CG}RUNNING${_CR}"
  else colour="${_CRD}STOPPED${_CR}"; fi

  local inner=$((MENU_WIDTH-2))
  local rpad=$(( inner-1-lw-sw ))
  [ "$rpad" -lt 0 ] && rpad=0

  printf '║ %s%s' "$label" "$colour"
  _rp ' ' "$rpad"
  printf '║\n'
}

# ── ASCII-art "DX PROXY" logo (centred automatically) ──
_logo() {
  local _l=(
    '██████╗ ██╗  ██╗   ██████╗ ██████╗  ██████╗ ██╗  ██╗ ██╗  ██╗'
    '██╔══██╗╚██╗██╔╝   ██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝ ╚██╗██╔╝'
    '██║  ██║ ╚███╔╝    ██████╔╝██████╔╝██║   ██║ ╚███╔╝   ╚███╔╝ '
    '██║  ██║ ██╔██╗    ██╔═══╝ ██╔══██╗██║   ██║ ██╔██╗    ██║   '
    '██████╔╝██╔╝ ██╗   ██║     ██║  ██║╚██████╔╝██╔╝ ██╗   ██║   '
    '╚═════╝ ╚═╝  ╚═╝   ╚═╝     ╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═╝   ╚═╝   '
  )
  local line
  for line in "${_l[@]}"; do _ctr "$line"; done
}

# ── menu option rows ──
_opts() {
  local _o=(
    '[1]  Show connection info     [5]  Enable/disable user'
    '[2]  List users               [6]  Reset panel password'
    '[3]  Add user                 [7]  Stats'
    '[4]  Remove user              [0]  Exit'
  )
  local o; for o in "${_o[@]}"; do _lft "$o"; done
}

# ── compact fallback when terminal < MENU_WIDTH columns ──
_compact() {
  echo "============= DX-Proxy ============="
  echo " [1] Info     [4] Remove  [7] Stats"
  echo " [2] Users    [5] Toggle  [0] Exit"
  echo " [3] Add      [6] Password"
  echo "===================================="
}

# Helper to present a numbered interactive list for user actions (stderr redirect avoids breaking capture)
_select_user() {
  local prompt="$1"
  local show_status="${2:-false}"

  local users=()
  local states=()

  while IFS=$'\t' read -r u e; do
    [ -z "$u" ] && continue
    users+=("$u")
    states+=("$e")
  done < <(jq -r '.users[] | "\(.user)\t\(.enabled)"' "$USERS_FILE" 2>/dev/null)

  local total=${#users[@]}
  if [ "$total" -eq 0 ]; then
    echo "No users found." >&2
    return 1
  fi

  echo "$prompt" >&2
  local i
  for ((i=0; i<total; i++)); do
    local idx=$((i + 1))
    if [ "$show_status" = "true" ]; then
      local status_text
      if [ "${states[i]}" = "true" ]; then
        status_text="${_CG}ENABLED${_CR}"
      else
        status_text="${_CRD}DISABLED${_CR}"
      fi
      printf "  [%d] %-16s (%s)\n" "$idx" "${users[i]}" "$status_text" >&2
    else
      printf "  [%d] %s\n" "$idx" "${users[i]}" >&2
    fi
  done
  echo "  [0] Cancel" >&2
  echo "" >&2

  while true; do
    read -rp "Select option (0-$total): " choice >&2
    if [ "$choice" = "0" ]; then
      return 1
    fi
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$total" ]; then
      local selected_idx=$((choice - 1))
      echo "${users[selected_idx]} ${states[selected_idx]}"
      return 0
    fi
    echo "Invalid choice. Please try again." >&2
  done
}

# ================= menu =================
cmd_menu() {
  while true; do
    _clear_screen
    _flush_stdin

    local cols
    cols=$(tput cols 2>/dev/null || echo 80)

    if [ "$cols" -lt "$MENU_WIDTH" ]; then
      _compact
    else
      _top
      _logo
      _sep
      _spt 'Creator: @COD-DEXTER' 'Version: 1.0.0'
      _sep
      _sts
      _sep
      _opts
      _bot
    fi

    read -rp "❯ " opt
    case "$opt" in
      1) cmd_info; read -rp "Press enter..." ;;
      2) cmd_users; read -rp "Press enter..." ;;
      3) read -rp "Label (blank=auto): " l; cmd_add_user "$l"; read -rp "Press enter..." ;;
      4) 
        local sel
        if sel=$(_select_user "Select a user to remove:" "false"); then
          local u
          u=$(echo "$sel" | awk '{print $1}')
          cmd_remove_user "$u"
        else
          echo "Operation cancelled."
        fi
        read -rp "Press enter..."
        ;;
      5) 
        local sel
        if sel=$(_select_user "Select a user to toggle status:" "true"); then
          local u current_state new_state
          u=$(echo "$sel" | awk '{print $1}')
          current_state=$(echo "$sel" | awk '{print $2}')
          if [ "$current_state" = "true" ]; then
            new_state="false"
          else
            new_state="true"
          fi
          cmd_set_enabled "$u" "$new_state"
        else
          echo "Operation cancelled."
        fi
        read -rp "Press enter..."
        ;;
      6) read -rp "username: " u; read -rp "password: " p; cmd_panel_password "$u" "$p"; read -rp "Press enter..." ;;
      7) cmd_stats; read -rp "Press enter..." ;;
      0) exit 0 ;;
      *) echo "Invalid option. Returning to menu..." >&2; sleep 1 ;;
    esac
  done
}

# ================= dispatch =================
case "$1" in
  ""|menu) cmd_menu ;;
  status) cmd_status "$2" ;;
  users) cmd_users "$2" ;;
  add-user) cmd_add_user "$2" ;;
  remove-user) cmd_remove_user "$2" ;;
  enable-user) cmd_set_enabled "$2" true ;;
  disable-user) cmd_set_enabled "$2" false ;;
  rotate-secret) cmd_rotate_secret "$2" ;;
  info) cmd_info "$2" ;;
  export) cmd_export ;;
  settings) cmd_settings "$2" ;;
  set-proxy) cmd_set_proxy "$2" ;;
  set-domain) cmd_set_domain "$2" ;;
  panel-password) cmd_panel_password "$2" "$3" ;;
  auth-status) cmd_auth_status "$2" ;;
  stats) cmd_stats ;;
  restart|reload) cmd_restart ;;
  logs) cmd_logs ;;
  backup) cmd_backup ;;
  restore) cmd_restore "$2" ;;
  new|reset-users) cmd_new ;;
  help) grep -E '^\s+[a-z-]+\)' "$0" | sed 's/)//' ;;
  *) echo "Unknown command: $1. Run 'dx help'." ; exit 1 ;;
esac
